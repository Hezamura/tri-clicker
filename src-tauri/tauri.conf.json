{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TriClick Studio",
  "version": "0.3.0",
  "identifier": "com.yasaki.triclick",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TriClick Studio",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 660,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
